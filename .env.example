# OpenAI (default provider)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini (set LLM_PROVIDER=gemini to use)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Provider selection: openai | gemini
LLM_PROVIDER=openai

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=2
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_USER=assistant
POSTGRES_PASSWORD=assistant
POSTGRES_DB=enterprise_ai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://assistant:assistant@localhost:5432/enterprise_ai

# Docker / nginx
NGINX_PORT=80
API_PORT=8000
