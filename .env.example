# OpenAI (default provider)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini (set LLM_PROVIDER=gemini to use)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Provider selection: openai | gemini
LLM_PROVIDER=gemini

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=2
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_USER=assistant
POSTGRES_PASSWORD=assistant
POSTGRES_DB=enterprise_ai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://assistant:assistant@localhost:5432/enterprise_ai

# Auth / JWT
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth - Google (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# OAuth - GitHub (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Password reset (local accounts only)
PASSWORD_RESET_EXPIRE_MINUTES=60
# Set true in dev to return reset link in API response when SMTP is not configured
EXPOSE_PASSWORD_RESET_URL=false

# Docker / nginx
NGINX_PORT=80
API_PORT=8000
FRONTEND_PORT=5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost
